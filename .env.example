PORT=8001
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Grading mode: cnn (default) | bedrock_only (no CNN needed) | mock (stub)
GRADING_MODE=cnn

# Bedrock models (used by bedrock_only and tiered escalation)
BEDROCK_MODEL_T1=amazon.nova-lite-v1:0
BEDROCK_MODEL_T2=
BEDROCK_MODEL_T3=amazon.nova-pro-v1:0
OPENAI_API_KEY=

# CNN path
CNN_MODEL_PATH=./models/grade_cnn_v1.pt
CONFIDENCE_THRESHOLD_T2=0.85
CONFIDENCE_THRESHOLD_T3=0.75

# Embedding model for /embed endpoint
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Wish score model (logistic regression)
WISH_SCORE_MODEL_PATH=./models/wish_logreg_v1.pkl

# Fit aggregates path
FIT_AGGREGATES_PATH=./data/processed/fit_aggregates.json
